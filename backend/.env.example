# ============================================================
# CropXpert AI — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains your passwords.
# ============================================================

# ── MySQL Database ────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=cropxpert
DB_PORT=3306

# ── OpenWeatherMap API ────────────────────────────────────────
# Free key at: https://openweathermap.org/api
# After registering, go to: API Keys tab → copy the key
OPENWEATHER_API_KEY=your_openweather_api_key_here
